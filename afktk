-- Mesin Kesedot Kursi
task.spawn(function()
    while task.wait(2) do -- Dicek setiap 2 detik pelan-pelan biar emulator ga berat
        pcall(function()
            local char = LocalPlayer.Character
            local hum = char and char:FindFirstChild("Humanoid")
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
            
            -- Kalau karakter ada, dan lagi BERDIRI (nggak duduk)
            if hum and hrp and not hum.Sit then
                local targetSeat = nil
                local closestDist = 50 -- Cari kursi kosong terdekat dalam 50 meter
                
                for _, obj in pairs(workspace:GetDescendants()) do
                    if obj:IsA("Seat") and not obj.Occupant then
                        local dist = (hrp.Position - obj.Position).Magnitude
                        if dist < closestDist then
                            closestDist = dist
                            targetSeat = obj
                        end
                    end
                end
                
                -- Kalau ada kursi kosong terdekat, JATUHKAN pantatnya dari atas!
                if targetSeat then
                    -- Posisi kursi + 2 meter ke atas biar jatuh alami dan otomatis duduk
                    hrp.CFrame = targetSeat.CFrame + Vector3.new(0, 2, 0)
                end
            end
        end)
    end
end)
